<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="kr.co.iei.subject.model.dao.SubjectDao">

<select id="selectSubjectList" resultType="subject">
	select * from subject_tbl 
	<where>
	    <if test="searchKeyword != null and searchKeyword != ''">
	        and subject_title like '%' || #{searchKeyword} || '%'
	    </if>
	    
	    
	    <if test="subjectCategory != null and subjectCategory != 0">
        and subject_category = #{subjectCategory}
	    </if>
	
	    <if test="subjectLevel != null and subjectLevel != 0">
	        and subject_level = #{subjectLevel}
	    </if>
	</where>
	
	
	<if test="order == 1">
        order by subject_no asc
    </if>

    <if test="order == 2">
        order by subject_level asc
    </if>

    <if test="order == 3">
        order by subject_level desc
    </if>

    <if test="order == 4">
        order by subject_count asc
    </if>

    <if test="order == 5">
        order by subject_count desc
    </if>
    


	
	
</select>

</mapper>
